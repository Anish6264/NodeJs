<!DOCTYPE html>
<html lang="en">

<head>
<%- include("./partials/head") %>
<title><%= blog.title %></title>
</head>

<body>

<%- include("./partials/nav") %>

<div class="container mt-4">

<h2><%= blog.title %></h2>

<img 
src="<%= blog.coverImage %>" 
class="img-fluid mb-3"
style="max-height:400px; object-fit:cover"
>

<p><%= blog.body %></p>

<hr>

<h4>Comments</h4>


<!-- SHOW COMMENTS -->

<% comments.forEach(comment => { %>

<div class="card mb-2">

<div class="card-body d-flex justify-content-between">

<div>

<strong><%= comment.createdBy.fullName %></strong>

<p class="mb-0"><%= comment.content %></p>

</div>


<!-- DELETE COMMENT BUTTON -->

<% if(locals.user && (
comment.createdBy._id.toString() === locals.user._id.toString()
||
blog.createdBy._id.toString() === locals.user._id.toString()
)){ %>

<form action="/blog/comment/delete/<%= comment._id %>" method="POST">

<button class="btn btn-sm btn-danger">
Delete
</button>

</form>

<% } %>

</div>

</div>

<% }) %>


<hr>


<!-- COMMENT FORM (ONLY IF LOGGED IN) -->

<% if(locals.user){ %>

<form action="/blog/comment/<%= blog._id %>" method="POST">

<div class="mb-3">

<textarea 
name="content" 
class="form-control"
placeholder="Write a comment..."
required
></textarea>

</div>

<button class="btn btn-primary">
Post Comment
</button>

</form>

<% } else { %>

<div class="alert alert-info">

Please <a href="/user/signin">login</a> to comment.

</div>

<% } %>

</div>

<%- include("./partials/script") %>

</body>
</html>